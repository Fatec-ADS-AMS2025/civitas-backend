Content-Type: application/json

{
  "idFornecedor": 1,
  "nomeFantasia": "Fornecedor XPTO",
  "situacao": 1,
  "cnpj": "12345678000199",
  "nome": "Fornecedor XPTO LTDA",
  "logradouro": "Rua A",
  "numero": "100",
  "bairro": "Centro",
  "cep": "01001000",
  "cidade": "Sao Paulo",
  "estado": "SP",
  "email": "contato@fornecedor.com"
}

