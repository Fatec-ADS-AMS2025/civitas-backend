@Civitas.WebAPI_HostAddress = http://localhost:5210
@authToken = cole-o-token-aqui

### Auth - Login
POST {{Civitas.WebAPI_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "usuario@example.com",
  "senha": "abc12345"
}

###

### Auditorias - Get All
GET {{Civitas.WebAPI_HostAddress}}/api/auditorias
Accept: application/json

### Auditorias - Get Inativos
GET {{Civitas.WebAPI_HostAddress}}/api/auditorias/inativos
Accept: application/json

### Auditorias - Get by ID
GET {{Civitas.WebAPI_HostAddress}}/api/auditorias/1
Accept: application/json

### Auditorias - Get by Usuario
GET {{Civitas.WebAPI_HostAddress}}/api/auditorias/usuario/1
Accept: application/json

### Auditorias - Get by Entidade
GET {{Civitas.WebAPI_HostAddress}}/api/auditorias/entidade?nomeEntidade=Usuario
Accept: application/json

### Auditorias - Get by Operacao
GET {{Civitas.WebAPI_HostAddress}}/api/auditorias/operacao?operacao=CREATE
Accept: application/json

### Auditorias - Post
POST {{Civitas.WebAPI_HostAddress}}/api/auditorias
Content-Type: application/json

{
  "nomeEntidade": "Usuario",
  "operacao": "CREATE",
  "valoresAtingidos": "nome",
  "novosValores": "Joao",
  "situacao": 1,
  "usuarioId": 1
}

### Auditorias - Change Situacao
PATCH {{Civitas.WebAPI_HostAddress}}/api/auditorias/situacao/1
Accept: application/json

###

### Despesas - Get All
GET {{Civitas.WebAPI_HostAddress}}/api/despesas
Accept: application/json

### Despesas - Get Inativos
GET {{Civitas.WebAPI_HostAddress}}/api/despesas/inativos
Accept: application/json

### Despesas - Get by ID
GET {{Civitas.WebAPI_HostAddress}}/api/despesas/1
Accept: application/json

### Despesas - Post
POST {{Civitas.WebAPI_HostAddress}}/api/despesas
Content-Type: application/json

{
  "numeroDocumento": "123",
  "uc": "UC001",
  "dataEmicao": "2026-03-17",
  "consumoPrevisto": 150,
  "dataVencimento": "2026-04-10",
  "situacao": 1
}

### Despesas - Put
PUT {{Civitas.WebAPI_HostAddress}}/api/despesas/1
Content-Type: application/json

{
  "id": 1,
  "numeroDocumento": "123",
  "uc": "UC001",
  "dataEmicao": "2026-03-17",
  "consumoPrevisto": 160,
  "dataVencimento": "2026-04-10",
  "situacao": 1
}

### Despesas - Change Situacao
PATCH {{Civitas.WebAPI_HostAddress}}/api/despesas/situacao/1
Accept: application/json

###

### Documentos - Get All
GET {{Civitas.WebAPI_HostAddress}}/api/documentos
Accept: application/json

### Documentos - Get by ID
GET {{Civitas.WebAPI_HostAddress}}/api/documentos/1
Accept: application/json

### Documentos - Post
POST {{Civitas.WebAPI_HostAddress}}/api/documentos
Content-Type: application/json

{
  "digitalizacao": "AQID",
  "numeroDocumento": 12345,
  "idFornecedor": 1,
  "idFluxo": 1
}

### Documentos - Put
PUT {{Civitas.WebAPI_HostAddress}}/api/documentos/1
Content-Type: application/json

{
  "idDocumento": 1,
  "digitalizacao": "AQID",
  "numeroDocumento": 12345,
  "idFornecedor": 1,
  "idFluxo": 1
}

